{
	"name": "pl_masterdata_API",
	"properties": {
		"activities": [
			{
				"name": "Energy_json_data_incremental",
				"type": "ExecutePipeline",
				"dependsOn": [],
				"policy": {
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"pipeline": {
						"referenceName": "pl_WorldBankIncrementalLoad_Energy",
						"type": "PipelineReference"
					},
					"waitOnCompletion": true,
					"parameters": {
						"LastLoadedYear": {
							"value": "@pipeline().parameters.LastLoadedYear",
							"type": "Expression"
						},
						"LoadDate": {
							"value": "@pipeline().parameters.LoadDate",
							"type": "Expression"
						},
						"CountryCode": {
							"value": "@pipeline().parameters.CountryCode",
							"type": "Expression"
						},
						"IndicatorCode": {
							"value": "@pipeline().parameters.IndicatorCode",
							"type": "Expression"
						}
					}
				}
			},
			{
				"name": "NB_Landing_Discovery",
				"type": "DatabricksNotebook",
				"dependsOn": [
					{
						"activity": "Energy_json_data_incremental",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"notebookPath": "/Users/kgnnet11@gmail.com/API_DATA_Transformations/Worldbank_energy_data/landing_discovey"
				},
				"linkedServiceName": {
					"referenceName": "ls_databriicks_Apl_dev",
					"type": "LinkedServiceReference"
				}
			},
			{
				"name": "NB_Discovery_Reporting",
				"type": "DatabricksNotebook",
				"dependsOn": [
					{
						"activity": "NB_Landing_Discovery",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"notebookPath": "/Users/kgnnet11@gmail.com/API_DATA_Transformations/Worldbank_energy_data/discovery_reporting"
				},
				"linkedServiceName": {
					"referenceName": "ls_databriicks_Apl_dev",
					"type": "LinkedServiceReference"
				}
			},
			{
				"name": "load_reportingzone_AzureTable",
				"type": "IfCondition",
				"dependsOn": [
					{
						"activity": "NB_Discovery_Reporting",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"expression": {
						"value": "\n@or(\n   equals(pipeline().parameters.TargetSystem, 'AzureTable'),\n   equals(pipeline().parameters.TargetSystem, 'Both')\n)",
						"type": "Expression"
					},
					"ifTrueActivities": [
						{
							"name": "cp_reportingzone_Azuretablestorage",
							"type": "Copy",
							"dependsOn": [],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "ParquetSource",
									"storeSettings": {
										"type": "AzureBlobFSReadSettings",
										"recursive": true,
										"wildcardFolderPath": {
											"value": "Worldbank/energy_data_reporting",
											"type": "Expression"
										},
										"wildcardFileName": "*.parquet",
										"enablePartitionDiscovery": false
									},
									"formatSettings": {
										"type": "ParquetReadSettings"
									}
								},
								"sink": {
									"type": "AzureTableSink",
									"azureTableInsertType": "merge",
									"azureTableDefaultPartitionKeyValue": "petrolake",
									"writeBatchSize": 10000
								},
								"enableStaging": false,
								"translator": {
									"type": "TabularTranslator",
									"typeConversion": true,
									"typeConversionSettings": {
										"allowDataTruncation": true,
										"treatBooleanAsNumber": false
									}
								}
							},
							"inputs": [
								{
									"referenceName": "ds_adls_reporting_worldbank_api",
									"type": "DatasetReference"
								}
							],
							"outputs": [
								{
									"referenceName": "ds_azuretable_worldbank_api",
									"type": "DatasetReference"
								}
							]
						}
					]
				}
			},
			{
				"name": "load_reportingzone_AzureSql",
				"type": "IfCondition",
				"dependsOn": [
					{
						"activity": "NB_Discovery_Reporting",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"expression": {
						"value": "\n@or(\n   equals(pipeline().parameters.TargetSystem, 'AzureSQL'),\n   equals(pipeline().parameters.TargetSystem, 'Both')\n)",
						"type": "Expression"
					},
					"ifTrueActivities": [
						{
							"name": "cp_reporting_azuresql",
							"type": "Copy",
							"dependsOn": [],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "ParquetSource",
									"storeSettings": {
										"type": "AzureBlobFSReadSettings",
										"recursive": true,
										"wildcardFolderPath": {
											"value": "Worldbank/energy_data_reporting",
											"type": "Expression"
										},
										"wildcardFileName": "*.parquet",
										"enablePartitionDiscovery": false
									},
									"formatSettings": {
										"type": "ParquetReadSettings"
									}
								},
								"sink": {
									"type": "AzureSqlSink",
									"writeBehavior": "insert",
									"sqlWriterUseTableLock": false
								},
								"enableStaging": false,
								"translator": {
									"type": "TabularTranslator",
									"typeConversion": true,
									"typeConversionSettings": {
										"allowDataTruncation": true,
										"treatBooleanAsNumber": false
									}
								}
							},
							"inputs": [
								{
									"referenceName": "ds_adls_reporting_worldbank_api",
									"type": "DatasetReference"
								}
							],
							"outputs": [
								{
									"referenceName": "ds_azuresql_worldbank_api",
									"type": "DatasetReference"
								}
							]
						}
					]
				}
			}
		],
		"parameters": {
			"TargetSystem": {
				"type": "string",
				"defaultValue": "Both"
			},
			"LastLoadedYear": {
				"type": "int",
				"defaultValue": 2022
			},
			"LoadDate": {
				"type": "string",
				"defaultValue": "2026-02-01"
			},
			"CountryCode": {
				"type": "string",
				"defaultValue": "IN"
			},
			"IndicatorCode": {
				"type": "string",
				"defaultValue": "EG.USE.PCAP.KG.OE"
			}
		},
		"annotations": []
	}
}