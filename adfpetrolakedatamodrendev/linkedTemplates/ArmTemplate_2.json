				"annotations": [],
				"type": "RestResource",
				"typeProperties": {
					"relativeUrl": "/petroleum/pri/spt/data/?api_key=DEMO_KEY&frequency=daily&data[0]=value&start=2024-01-01&end=2024-12-31"
