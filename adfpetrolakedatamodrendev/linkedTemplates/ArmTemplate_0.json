		"LS_HttpServer_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://api.worldbank.org"
		},
		"LS_WorldBank_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://api.worldbank.org"
		},
		"ls_alds_landingzone_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://sgdigitalizationdev.dfs.core.windows.net/"
		},
		"ls_azuresql_petrolake_dev_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sqlserverpetrolake.database.windows.net"
		},
		"ls_azuresql_petrolake_dev_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "db_petrolake_dev"
		},
		"ls_azuresql_petrolake_dev_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sqladmin"
		},
		"ls_databricks_petrolake_dev_properties_typeProperties_existingClusterId": {
			"type": "string",
			"defaultValue": "0214-132145-bvcoilg0"
		},
		"ls_databriicks_Apl_dev_properties_typeProperties_existingClusterId": {
			"type": "string",
			"defaultValue": "0223-030315-yim4knuo"
		},
		"ls_eia_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://api.eia.gov/v2"
		},
		"ls_rest_api_wroldbank_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://api.worldbank.org/v2"
		},
		"ls_rest_eia_wti_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://api.eia.gov"
		},
