			"type": "string",
			"defaultValue": "https://api.worldbank.org/v2/country/IN/indicator/EG.USE.PCAP.KG.OE"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
