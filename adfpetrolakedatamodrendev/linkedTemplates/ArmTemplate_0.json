{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adfpetrolakedatamodrendev"
		},
		"ls_alds_landingzone_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_alds_landingzone'"
		},
		"ls_azuresql_petrolake_dev_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_azuresql_petrolake_dev'"
		},
		"ls_azuretable_storage_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ls_azuretable_storage'"
		},
		"ls_blob_filesystem_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ls_blob_filesystem'"
		},
		"ls_databricks_petrolake_dev_accessToken": {
			"type": "secureString",
			"metadata": "Secure string for 'accessToken' of 'ls_databricks_petrolake_dev'"
