{
	"name": "dataflows_clean_process_csv",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "ls_alds_landingzone",
						"type": "LinkedServiceReference"
					},
					"name": "Customer"
				},
				{
					"linkedService": {
						"referenceName": "ls_alds_landingzone",
						"type": "LinkedServiceReference"
					},
					"name": "orders"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "ls_alds_landingzone",
						"type": "LinkedServiceReference"
					},
					"name": "loadoutput"
				}
			],
			"transformations": [
				{
					"name": "AddNewcolumns"
				},
				{
					"name": "RemoveBadRequest"
				},
				{
					"name": "selectNeedColumns"
				}
			],
			"scriptLines": [
				"source(useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delimited',",
				"     fileSystem: 'dataflows',",
				"     folderPath: 'input',",
				"     fileName: 'customers-1000.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> Customer",
				"source(useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delimited',",
				"     fileSystem: 'dataflows',",
				"     folderPath: 'input',",
				"     fileName: 'orders_sample.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true,",
				"     multiLineRow: true) ~> orders",
				"Customer derive(fullname = concat(byName('First Name'), ' ',byName('Last Name')),",
				"          subscription_year = year(toDate(byName('Subscription Date'),'yyyy-MM-dd')),",
				"          subscription_month = month(toDate(byName('Subscription Date'), 'yyyy-MM-dd')),",
				"          country_upper = upper(byName('Country'))) ~> AddNewcolumns",
				"AddNewcolumns filter(!isNull(byName('Email')) && !isNull(byName('Customer Id'))) ~> RemoveBadRequest",
				"RemoveBadRequest select(skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectNeedColumns",
				"selectNeedColumns sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delta',",
				"     fileSystem: 'dataflows',",
				"     folderPath: 'ouput',",
				"     mergeSchema: false,",
				"     autoCompact: false,",
				"     optimizedWrite: true,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: true,",
				"     updateable: false,",
				"     upsertable: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> loadoutput"
			]
		}
	}
}