{
	"name": "dataflows_clean_process_csv",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "ls_alds_landingzone",
						"type": "LinkedServiceReference"
					},
					"name": "Customer"
				},
				{
					"linkedService": {
						"referenceName": "ls_alds_landingzone",
						"type": "LinkedServiceReference"
					},
					"name": "orders"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "AddNewcolumns"
				}
			],
			"scriptLines": [
				"source(useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delimited',",
				"     fileSystem: 'dataflows',",
				"     folderPath: 'input',",
				"     fileName: 'customers-1000.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> Customer",
				"source(useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delimited',",
				"     fileSystem: 'dataflows',",
				"     folderPath: 'input',",
				"     fileName: 'orders_sample.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true,",
				"     multiLineRow: true) ~> orders",
				"Customer derive(fullname = concat(byName('First Name'), ' ',byName('Last Name')),",
				"          subscription_year = year(toDate(byName('Subscription Date'),'dd-MM-yyyy')),",
				"          subscription_month = month(toDate(byName('Subscription Date'), 'dd-MM-yyyy')),",
				"          country_upper = upper(byName('Country'))) ~> AddNewcolumns"
			]
		}
	}
}